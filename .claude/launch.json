{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["server:app", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "port": 8001,
      "cwd": "backend"
    },
    {
      "name": "frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start"],
      "port": 3000,
      "cwd": "frontend"
    }
  ]
}
